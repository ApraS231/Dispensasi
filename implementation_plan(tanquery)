### Fase 3: QueryClient Configuration

#### [MODIFY] [_layout.tsx](file:///c:/laragon/www/SIdispen%20(SMA%203)/mobile-app/app/_layout.tsx)

```diff
- const queryClient = new QueryClient();
+ import { focusManager } from '@tanstack/react-query';
+ import { AppState, Platform } from 'react-native';
+ 
+ // Auto refetch on app focus (React Native specific)
+ focusManager.setEventListener(handleFocus => {
+   const subscription = AppState.addEventListener('change', state => {
+     handleFocus(state === 'active');
+   });
+   return () => subscription.remove();
+ });
+ 
+ const queryClient = new QueryClient({
+   defaultOptions: {
+     queries: {
+       staleTime: 30 * 1000,       // 30 detik sebelum data dianggap stale
+       gcTime: 10 * 60 * 1000,      // 10 menit garbage collection
+       retry: 2,
+       refetchOnWindowFocus: true,   // Refetch saat app kembali ke foreground
+       refetchOnReconnect: true,
+     },
+   },
+ });
```


### Fase 2: Service Layer + Query Hooks

> [!TIP]
> Sentralisasi semua API call dan query config di `src/services/` agar konsisten dan DRY.

#### [NEW] src/services/dispensasiService.ts
```typescript
import api from '../utils/api';

export const dispensasiService = {
  getMyTickets: () => api.get('/dispensasi/me').then(r => r.data),
  getAll: () => api.get('/dispensasi').then(r => r.data),
  getPending: () => api.get('/dispensasi/pending').then(r => r.data),
  getById: (id: string) => api.get(`/dispensasi/${id}`).then(r => r.data),
  store: (formData: FormData) => api.post('/dispensasi', formData, {
    headers: { 'Content-Type': 'multipart/form-data' }
  }),
  approve: (id: string) => api.post(`/dispensasi/${id}/approve`),
  reject: (id: string, catatan: string) => 
    api.post(`/dispensasi/${id}/reject`, { catatan_penolakan: catatan }),
  monitoringAnak: () => api.get('/monitoring/anak').then(r => r.data),
};
```

#### [NEW] src/hooks/useDispensasiQueries.ts
```typescript
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
import { dispensasiService } from '../services/dispensasiService';

export const queryKeys = {
  myTickets: ['dispensasi-me'] as const,
  allTickets: ['dispensasi-all'] as const,
  pendingTickets: ['dispensasi-pending'] as const,
  ticketDetail: (id: string) => ['dispensasi', id] as const,
  monitoringAnak: ['monitoring-anak'] as const,
  dailyLog: ['piket-daily-log'] as const,
  notifications: ['notifications'] as const,
};

export function useMyTickets() {
  return useQuery({
    queryKey: queryKeys.myTickets,
    queryFn: dispensasiService.getMyTickets,
  });
}

export function useApproveTicket() {
  const queryClient = useQueryClient();
  return useMutation({
    mutationFn: (id: string) => dispensasiService.approve(id),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: queryKeys.pendingTickets });
      queryClient.invalidateQueries({ queryKey: queryKeys.allTickets });
      queryClient.invalidateQueries({ queryKey: queryKeys.dailyLog });
    },
  });
}

// ... more hooks per action
```


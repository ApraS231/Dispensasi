##### [NEW] `src/stores/themeStore.ts`

```typescript
import { create } from 'zustand';
import AsyncStorage from '@react-native-async-storage/async-storage';

interface ThemeState {
  mode: 'light' | 'dark' | 'system';
  setMode: (mode: 'light' | 'dark' | 'system') => void;
  loadSavedTheme: () => Promise<void>;
}

export const useThemeStore = create<ThemeState>((set) => ({
  mode: 'system',
  setMode: async (mode) => {
    set({ mode });
    await AsyncStorage.setItem('themeMode', mode);
  },
  loadSavedTheme: async () => {
    const saved = await AsyncStorage.getItem('themeMode');
    if (saved) set({ mode: saved as any });
  },
}));
```

##### [NEW] `src/hooks/useThemeColors.ts`

Hook yang return warna aktif berdasarkan state tema + system preference (`useColorScheme`):
```typescript
import { useColorScheme } from 'react-native';
import { useThemeStore } from '../stores/themeStore';
import { COLORS, DARK_COLORS } from '../utils/theme';

export function useThemeColors() {
  const systemScheme = useColorScheme();
  const mode = useThemeStore((s) => s.mode);
  const isDark = mode === 'dark' || (mode === 'system' && systemScheme === 'dark');
  return isDark ? DARK_COLORS : COLORS;
}
```

